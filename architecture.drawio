        <mxCell id="e3" value="SQL" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;labelBackgroundColor=#ffffff;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="L3" target="db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="a1" value="Parse the request, call ONE service, jsonify the result. No business logic, no DB queries. A service ValueError is caught here → 4xx JSON." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#7f4f00;" vertex="1" parent="1">
          <mxGeometry x="940" y="140" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="All business logic and DB access. Every bug in the hunt lived here. Validates inputs (raises ValueError), commits, and returns dicts — never ORM objects." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#33557f;" vertex="1" parent="1">
          <mxGeometry x="940" y="310" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="Schema + association tables. to_dict() is the serialization boundary crossed on the way back up." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#4d6b33;" vertex="1" parent="1">
          <mxGeometry x="940" y="480" width="230" height="90" as="geometry" />
        </mxCell>
